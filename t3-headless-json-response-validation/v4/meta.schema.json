{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["title", "robots"],
  "properties": {
    "title":        { "type": "string", "minLength": 1 },
    "description":  { "type": "string" },
    "ogTitle":      { "type": "string" },
    "ogDescription":{ "type": "string" },
    "ogImage":      { "type": "string", "pattern": "^/fileadmin/" },
    "robots":       { "type": "string", "pattern": "^(index|noindex),(follow|nofollow)$" },
    "canonical":    { "type": "string", "pattern": "^https?://" },
    "twitterCard":  { "type": "string", "enum": ["summary","summary_large_image","app","player"] }
  },
  "additionalProperties": true
}
