{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["colPos0"],
  "properties": {
    "colPos0": { "type": "array", "items": { "$ref": "#/definitions/contentElement" } },
    "colPos1": { "type": "array", "items": { "$ref": "#/definitions/contentElement" } },
    "colPos2": { "type": "array", "items": { "$ref": "#/definitions/contentElement" } }
  },
  "definitions": {
    "contentElement": {
      "type": "object",
      "required": ["id", "type", "content"],
      "properties": {
        "id":         { "type": "integer", "minimum": 1 },
        "type":       { "type": "string" },
        "colPos":     { "type": "integer" },
        "appearance": { "type": "object" },
        "content": {
          "type": "object",
          "required": ["header"],
          "properties": {
            "header":       { "type": "string" },
            "headerLayout": { "type": "integer" },
            "bodytext":     { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
