# =============================================================================
# .gitignore — TYPO3 Headless Testing
#
# ⚠️  RGPD : les snapshots JSON peuvent contenir des titres/slugs de pages
#     réelles. Ils sont générés localement et ne doivent JAMAIS être versionnés.
#
# Les fixtures CSV (Tests/Fixtures/Database/) sont VERSIONNÉES
# car anonymisées (~50 Ko) et nécessaires au travail hors-ligne.
# =============================================================================

# -----------------------------------------------------------------------------
# Snapshots JSON — gitignorés (générés par PHPUnit, artifacts CI éphémères)
# -----------------------------------------------------------------------------
Tests/Fixtures/Snapshots/

# -----------------------------------------------------------------------------
# Dépendances PHP
# -----------------------------------------------------------------------------
/vendor/

# -----------------------------------------------------------------------------
# Cache Composer
# -----------------------------------------------------------------------------
.cache/

# -----------------------------------------------------------------------------
# Fichiers temporaires TYPO3
# -----------------------------------------------------------------------------
typo3temp/
typo3conf/

# -----------------------------------------------------------------------------
# DDEV (config locale)
# -----------------------------------------------------------------------------
.ddev/config.yaml.local

# -----------------------------------------------------------------------------
# Variables d'environnement locales
# -----------------------------------------------------------------------------
.env.local
.env.test.local
.env.*.local

# -----------------------------------------------------------------------------
# Éditeurs et OS
# -----------------------------------------------------------------------------
.DS_Store
.idea/
.vscode/settings.json
*.swp

# -----------------------------------------------------------------------------
# Résultats de tests
# -----------------------------------------------------------------------------
typo3temp/var/tests/
playwright-results/
