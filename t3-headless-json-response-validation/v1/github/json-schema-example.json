{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "type", "title", "slug", "content"],
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1,
      "description": "Identifiant unique de la page"
    },
    "type": {
      "type": "string",
      "enum": ["pages"],
      "description": "Type de contenu"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Titre de la page"
    },
    "slug": {
      "type": "string",
      "pattern": "^/[a-zA-Z0-9\\-/]+$",
      "description": "URL de la page"
    },
    "content": {
      "type": "object",
      "required": ["elements"],
      "properties": {
        "elements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "type", "content"],
            "properties": {
              "id": {
                "type": "integer",
                "description": "Identifiant de l'élément"
              },
              "type": {
                "type": "string",
                "enum": ["text", "image", "video"],
                "description": "Type de contenu"
              },
              "content": {
                "type": "object",
                "required": ["header", "bodytext"],
                "properties": {
                  "header": {
                    "type": "string",
                    "description": "Titre de l'élément"
                  },
                  "bodytext": {
                    "type": "string",
                    "description": "Contenu texte"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}