# =============================================================================
# .gitignore — TYPO3 Headless Testing
#
# ⚠️  SÉCURITÉ RGPD :
#   Les données de test (fixtures CSV et snapshots JSON) ne doivent
#   JAMAIS être versionnées — elles peuvent contenir des données de
#   pages réelles (titres, slugs, métadonnées) ou des données anonymisées
#   issues de la base de production.
# =============================================================================

# -----------------------------------------------------------------------------
# Fixtures CSV — données de test (générées localement par generate_fixtures.sh)
# -----------------------------------------------------------------------------
Tests/Fixtures/Database/

# -----------------------------------------------------------------------------
# Snapshots JSON — photos de réponses API (générés par PHPUnit)
# -----------------------------------------------------------------------------
Tests/Fixtures/Snapshots/

# -----------------------------------------------------------------------------
# Dépendances PHP
# -----------------------------------------------------------------------------
/vendor/

# -----------------------------------------------------------------------------
# Cache Composer
# -----------------------------------------------------------------------------
.cache/

# -----------------------------------------------------------------------------
# Fichiers temporaires TYPO3
# -----------------------------------------------------------------------------
typo3temp/
typo3conf/

# -----------------------------------------------------------------------------
# Fichiers DDEV locaux (credentials, config locale)
# -----------------------------------------------------------------------------
.ddev/config.yaml.local
.ddev/.gitignore

# -----------------------------------------------------------------------------
# Variables d'environnement locales
# -----------------------------------------------------------------------------
.env.local
.env.test.local
.env.*.local

# -----------------------------------------------------------------------------
# Éditeurs et OS
# -----------------------------------------------------------------------------
.DS_Store
.idea/
.vscode/settings.json
*.swp
*.swo

# -----------------------------------------------------------------------------
# Résultats de tests
# -----------------------------------------------------------------------------
typo3temp/var/tests/
playwright-results/
test-results/
